<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow (using an inset) -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_shadow" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Glass Background -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_dark" /> <!-- Semi-transparent background -->
            <stroke android:width="1dp" android:color="@color/glass_stroke" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>