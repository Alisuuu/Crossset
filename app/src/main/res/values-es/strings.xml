    <string name="desc_stay_on">Evita que la pantalla se apague mientras el dispositivo se está cargando.</string>
    <string name="desc_screen_brightness">Ajusta el nivel de brillo manual de la pantalla.</string>
    <string name="desc_screen_timeout">Duración en milisegundos antes de que la pantalla se apague automáticamente.</string>
    <string name="desc_rotation">Activa o desactiva la rotación automática de la pantalla.</string>
    <string name="desc_roaming">Permite que el dispositivo se conecte a redes de datos en roaming.</string>
    <string name="desc_install_non_market">Permite la instalación de aplicaciones de fuentes ajenas a la Play Store.</string>

