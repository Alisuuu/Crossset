    <!-- Descriptions (Example) -->
    <string name="desc_animator_speed">Global scale for property-based animations. 0.5 makes them faster, 0.0 disables them.</string>
    <string name="desc_window_speed">Scale for window transition animations. Affects opening/closing app windows.</string>
    <string name="desc_transition_speed">Scale for in-app transition animations between different activities.</string>
    <string name="desc_font_scale">System-wide font scaling factor (1.0 is default, 1.15 is large).</string>
    <string name="desc_adb_enabled">Enables Android Debug Bridge (ADB) for USB debugging and shell access.</string>
    <string name="desc_show_touches">Shows a visual white dot feedback at the location of every screen touch.</string>
    <string name="desc_pointer_speed">Speed of the mouse or trackpad pointer (Range: -7 to +7).</string>
    <string name="desc_stay_on">Prevents the screen from sleeping while the device is plugged into a power source.</string>
    <string name="desc_screen_brightness">Adjusts the manual screen brightness level (0-255).</string>
    <string name="desc_screen_timeout">Duration in milliseconds before the screen turns off due to inactivity.</string>
    <string name="desc_rotation">Master switch for automatic screen rotation based on the accelerometer.</string>
    <string name="desc_roaming">Allows the device to connect to data networks while roaming on other carriers.</string>
    <string name="desc_install_non_market">Legacy setting to allow app installation from sources outside the Play Store.</string>
    <string name="desc_auto_time">Synchronizes system time automatically using network (NTP) servers.</string>
    <string name="desc_auto_timezone">Automatically sets the device timezone based on network location.</string>
    <string name="desc_vibrate_on_touch">Provides haptic feedback (vibration) when interacting with the UI.</string>
    <string name="desc_haptic_feedback">Master switch for system-wide haptic feedback effects.</string>
    <string name="desc_airplane_mode">Disables all wireless radios (Cellular, WiFi, Bluetooth).</string>
    <string name="desc_location_mode">Defines accuracy for location services (0:Off, 3:High Accuracy).</string>
    <string name="desc_low_power_trigger">Battery percentage (0-100) that triggers Battery Saver mode automatically.</string>
    <string name="desc_zen_mode">Current Do Not Disturb (DND) status (0:Off, 1:On, 2:Alarms only).</string>
    <string name="desc_development_settings">Enables the \"Developer Options\" menu in the system settings.</string>
    <string name="desc_user_setup_complete">Flag indicating if the device\'s initial setup wizard was finished.</string>
    <string name="desc_bluetooth_on">Main radio state for Bluetooth connectivity.</string>
    <string name="desc_wifi_on">Main radio state for WiFi connectivity.</string>
    <string name="desc_data_enabled">Master switch for mobile data connectivity.</string>
    <string name="desc_accelerometer_rotation">Enables or disables rotation based on the physical position of the device.</string>
    <string name="desc_volume_ring">System-wide volume level for the phone ringtone.</string>
    <string name="desc_volume_music">System-wide volume level for media and music playback.</string>
    <string name="desc_volume_alarm">System-wide volume level for alarms.</string>
    
